# ─────────────────────────────────────────────────────────────
#  WAIBOT // Neural WhatsApp Interface - Environment Config
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000

# ── AI PROVIDERS ──────────────────────────────────────────────
# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── DATABASE (optional defaults) ──────────────────────────────
# These can also be set from the UI
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=my_database
DB_USER=root
DB_PASS=
